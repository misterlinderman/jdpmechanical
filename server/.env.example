# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
# Get this from MongoDB Atlas: Connect -> Connect your application
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/jdpmechanical?retryWrites=true&w=majority

# Auth0 Configuration
# Get these from your Auth0 Application/API Settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=http://localhost:3001/api

# Auth0 Management API (Machine-to-Machine app) — required for /api/admin/auth0/* (admin UI: Users & roles)
# Grant: read:users, read:roles, assign:roles (Auth0 Management API)
# AUTH0_MANAGEMENT_CLIENT_ID=
# AUTH0_MANAGEMENT_CLIENT_SECRET=

# Production only (no trailing slash — must match browser Origin for CORS)
CLIENT_URL=https://your-production-domain.com

# Public SPA URL used inside QR links (production)
# APP_DOMAIN=https://your-frontend-domain.com

# AWS S3 — optional for local dev (without these, QR may use inline data URLs)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=
# S3_PUBLIC_URL_BASE=   # optional; e.g. CloudFront base without trailing slash

# Optional: npm run seed:demo — use this MongoDB user for staged units + scan events
# SEED_ACTOR_EMAIL=you@example.com
